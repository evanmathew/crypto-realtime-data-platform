[0m23:56:22.807955 [debug] [Thread-2 (]: On model.crypto_pipeline.mart_crypto_daily_ohlc: create or replace  temporary view CRYPTO_DB.MARTS.mart_crypto_daily_ohlc__dbt_tmp
  
  
  
  
  as (
    -- mart_crypto_daily_ohlc.sql
-- Daily OHLC (Open/High/Low/Close) per coin



with hourly as (

    select *
    from CRYPTO_DB.INTERMEDIATE.int_crypto_hourly

    

        where cast(hour_bucket as date) >
        (
            select max(trade_date)
            from CRYPTO_DB.MARTS.mart_crypto_daily_ohlc
        )

    

),

daily as (

    select
        coin_id,
        symbol,
        name,

        date_trunc('day', hour_bucket) as trade_date,

        max(max_price_usd) as high_usd,
        min(min_price_usd) as low_usd,
        avg(avg_price_usd) as avg_price_usd,

        first_value(avg_price_usd) over (
            partition by coin_id, date_trunc('day', hour_bucket)
            order by hour_bucket asc
            rows between unbounded preceding and unbounded following
        ) as open_usd,

        last_value(avg_price_usd) over (
            partition by coin_id, date_trunc('day', hour_bucket)
            order by hour_bucket asc
            rows between unbounded preceding and unbounded following
        ) as close_usd,

        sum(avg_volume_usd) as total_volume_usd,
        max(all_time_high_usd) as all_time_high_usd,
        sum(record_count) as total_records

    from hourly

    group by
        coin_id,
        symbol,
        name,
        date_trunc('day', hour_bucket),
        hour_bucket,
        avg_price_usd

)

select
    d.coin_id,
    d.symbol,
    d.name,
    d.trade_date,
    d.open_usd,
    d.high_usd,
    d.low_usd,
    d.close_usd,
    d.avg_price_usd,
    d.total_volume_usd,
    d.all_time_high_usd,

    round(
        (
            (d.close_usd - d.open_usd)
            / nullif(d.open_usd, 0)
        ) * 100,
        4
    ) as daily_return_pct,

    d.total_records

from daily d
  )

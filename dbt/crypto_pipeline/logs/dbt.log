  as (
    -- int_crypto_hourly.sql
-- Aggregates staging data into hourly snapshots per coin



with staging as (
    
    select *
    from CRYPTO_DB.STAGING.stg_crypto_prices

    

        where ingested_at >
        (
            select max(hour_bucket)
            from CRYPTO_DB.INTERMEDIATE.int_crypto_hourly
        )

    
),

hourly as (
    select
        coin_id,
        symbol,
        name,
        date_trunc('hour', ingested_at)         as hour_bucket,
        avg(current_price_usd)                   as avg_price_usd,
        max(current_price_usd)                   as max_price_usd,
        min(current_price_usd)                   as min_price_usd,
        avg(market_cap_usd)                      as avg_market_cap_usd,
        avg(total_volume_usd)                    as avg_volume_usd,
        avg(price_change_pct_24h)                as avg_price_change_pct_24h,
        max(all_time_high_usd)                   as all_time_high_usd,
        min(all_time_low_usd)                    as all_time_low_usd,
        count(*)                                 as record_count
    from staging
    group by 1, 2, 3, 4
)

select * from hourly
  )
/* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "crypto_pipeline", "target_name": "dev", "node_id": "model.crypto_pipeline.int_crypto_hourly"} */;
[0m00:52:48.562888 [debug] [Thread-5 (]: On model.crypto_pipeline.int_crypto_market_dominance: create or replace  temporary view CRYPTO_DB.INTERMEDIATE.int_crypto_market_dominance__dbt_tmp
  
  
  
  
  as (
    -- int_crypto_market_dominance.sql
-- Calculates each coin's market dominance % per ingestion snapshot



with staging as (
    select * from CRYPTO_DB.STAGING.stg_crypto_prices

    

        where ingested_at >
        (
            select max(ingested_at)
            from CRYPTO_DB.INTERMEDIATE.int_crypto_market_dominance
        )

    
    
),

total_market as (
    select
        ingested_at,
        sum(market_cap_usd) as total_market_cap_usd
    from staging
    group by ingested_at
),

dominance as (
    select
        s.coin_id,
        s.symbol,
        s.name,
        s.ingested_at,
        s.current_price_usd,
        s.market_cap_usd,
        t.total_market_cap_usd,
        round(
            (s.market_cap_usd / nullif(t.total_market_cap_usd, 0)) * 100, 4
        )                                        as market_dominance_pct,
        s.total_volume_usd,
        s.price_change_pct_24h
    from staging s
    left join total_market t
        on s.ingested_at = t.ingested_at
)

select * from dominance
  )
/* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "crypto_pipeline", "target_name": "dev", "node_id": "model.crypto_pipeline.int_crypto_market_dominance"} */;

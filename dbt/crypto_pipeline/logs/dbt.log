[0m20:17:00.566710 [debug] [Thread-5 (]: On model.crypto_pipeline.int_crypto_market_dominance: create or replace   view CRYPTO_DB.STAGING_INTERMEDIATE.int_crypto_market_dominance
  
  
  
  
  as (
    -- int_crypto_market_dominance.sql
-- Calculates each coin's market dominance % per ingestion snapshot

with staging as (
    select * from CRYPTO_DB.STAGING_STAGING.stg_crypto_prices
),

total_market as (
    select
        ingested_at,
        sum(market_cap_usd) as total_market_cap_usd
    from staging
    group by ingested_at
),

dominance as (
    select
        s.coin_id,
        s.symbol,
        s.name,
        s.ingested_at,
        s.current_price_usd,
        s.market_cap_usd,
        t.total_market_cap_usd,
        round(
            (s.market_cap_usd / nullif(t.total_market_cap_usd, 0)) * 100, 4
        )                                        as market_dominance_pct,
        s.total_volume_usd,
        s.price_change_pct_24h
    from staging s
    left join total_market t
        on s.ingested_at = t.ingested_at
)

select * from dominance
  )

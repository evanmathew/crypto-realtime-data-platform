        values ("COIN_ID", "COIN_ID_RAW", "SYMBOL", "NAME", "CURRENT_PRICE_USD", "MARKET_CAP_USD", "MARKET_CAP_RANK", "TOTAL_VOLUME_USD", "HIGH_24H_USD", "LOW_24H_USD", "PRICE_CHANGE_24H_USD", "PRICE_CHANGE_PCT_24H", "CIRCULATING_SUPPLY", "TOTAL_SUPPLY", "ALL_TIME_HIGH_USD", "ALL_TIME_LOW_USD", "LAST_UPDATED_AT", "INGESTED_AT", "SOURCE", "DBT_UPDATED_AT", "DBT_VALID_FROM", "DBT_VALID_TO", "DBT_SCD_ID")


